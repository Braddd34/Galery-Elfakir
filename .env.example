# Base de données (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Production : au moins 32 caractères — openssl rand -base64 32

# Cron Vercel (nettoyage tokens / sessions) — obligatoire en production
CRON_SECRET="" # openssl rand -hex 32 — même valeur que dans le cron Vercel (Authorization Bearer)

# Setup unique (création admin) — production : min. 24 caractères
SETUP_SECRET=""

# Cloudflare Turnstile (anti-bot login) — si TURNSTILE_SECRET_KEY est défini, la connexion l'exige côté serveur
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Vercel Blob (Images)
BLOB_READ_WRITE_TOKEN=""

# Resend (Emails)
RESEND_API_KEY=""
FROM_EMAIL="" # Email vérifié dans Resend (ex: contact@votredomaine.com)

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="https://galeryelfakir.vercel.app" # URL canonique (utilisée pour SEO, sitemap, OG)

# Sentry — Suivi des erreurs (optionnel mais recommandé en production)
# Si vide, Sentry est désactivé.
NEXT_PUBLIC_SENTRY_DSN=""        # DSN public (client) — fourni par Sentry
SENTRY_DSN=""                    # DSN serveur (souvent identique au public)
SENTRY_ORG=""                    # Slug organisation Sentry (pour upload source maps)
SENTRY_PROJECT=""                # Slug projet Sentry
SENTRY_AUTH_TOKEN=""             # Token avec scope project:releases (upload source maps)
